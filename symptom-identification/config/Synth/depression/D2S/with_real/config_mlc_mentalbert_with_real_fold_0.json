{
    "info": {
        "session": "MultiLabelClassification",
        "model": "mentalbert",
        "data": "Synth/D2S",
        "option": "depression/with_real/ckp_fold_0",
        "fold": 0,
        "seed": 42,
        "mode": "train"
    },

    "device": "gpu",
    "n_gpu": 1,
    "eval": "test",

    "arch": {
        "type": "BertMultiLabelClassification",
        "args": {
            "model_type": "mental/mental-bert-base-uncased",
            "num_labels": -1
        }
    },

    "resume": "",

    "data_loader": {
        "type": "SymptomDataset",
        "max_length": 256,
        "data_dir": "./data/D2S/depression/all_normalized.csv",
        "dict_dir": "./data/D2S/depression/symptom_dictionary.json",
        "label_cols": "label",
        "text_cols": "normalized_post",
        "batch_size": 64
    },

    "optimizer": {
        "type": "AdamW",
        "args":{
            "lr": 3e-5,
            "eps": 1e-08
        }
    },

    "loss": "bce_with_logits",

    "metrics": {
        "calculator": [
        "accuracy", "precision", "recall", "f1score"
    ],
        "threshold": 0.5,
        "target_name": []
},

    "lr_scheduler": {
        "use": true,
        "warmup_proportion": 0.1
    },

    "trainer": {
        "epochs": 20,
        "save_dir": "saved/",
        "save_period": 5,
        "verbosity": 2,
        "monitor": "min val_loss",
        "early_stop": 3,
        "tensorboard": false
    }

}
